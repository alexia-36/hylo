generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model Visited {
  id         String    @id @default(cuid())

  name       String
  imageUrl   String?

  userId     String

  latitude  Float?
  longitude Float?
 
  createdAt  DateTime  @default(now())
  rating   Int?
}


model Favourite {
  id         String    @id @default(cuid())

  name       String
  imageUrl   String?

  userId     String
  note String? @default("")

  createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt 
}