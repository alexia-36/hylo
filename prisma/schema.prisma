generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model Visited {
  id         String    @id @default(cuid())

  name       String
  imageUrl   String?

  userId     String
 
  createdAt  DateTime  @default(now())
}


model Favourite {
  id         String    @id @default(cuid())

  name       String
  imageUrl   String?

  userId     String

  createdAt  DateTime  @default(now())
}